<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    <div class="ambient-glow-2"></div>

    <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px;">
            <a href="#calculo" title="Cálculo Diferencial"><i class="fa-solid fa-wave-square"></i> Cálculo</a>
            <a href="#integrales" title="Integrales"><i class="fa-solid fa-chart-area"></i> Integrales</a>
            <a href="#algebra" title="Álgebra"><i class="fa-solid fa-vector-square"></i> Álgebra</a>
            <a href="#fisica" title="Física"><i class="fa-solid fa-bolt"></i> Física</a>
        </div>

        <div class="nav-links">
            <a href="/history" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Cerrar Sesión"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="container">
        
        <div class="hero-section">
            <div class="welcome-badge"><i class="fa-solid fa-user-astronaut"></i> Sesión Activa</div>
            <h1 class="hero-title">Hola, <%= user.username %></h1>
        </div>

        <div id="calculo" class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-wave-square" style="color:#a855f7;"></i> Cálculo Diferencial</h2>
            <div class="section-line"></div>
        </div>
        <div class="dashboard-grid">
            <a href="/gradient" class="tool-card card-grad">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-arrow-trend-up"></i></div>
                <div class="card-content"><h3>Gradiente</h3><p>Máximo crecimiento $\nabla f$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/divergence" class="tool-card card-div">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-maximize"></i></div>
                <div class="card-content"><h3>Divergencia</h3><p>Flujo neto $\nabla \cdot \vec{F}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/rotacional" class="tool-card card-rot">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-rotate"></i></div>
                <div class="card-content"><h3>Rotacional</h3><p>Tendencia de giro $\nabla \times \vec{F}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
        </div>

        <div id="integrales" class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-chart-area" style="color:#ef4444;"></i> Integración y Gráficas</h2>
            <div class="section-line"></div>
        </div>
        <div class="dashboard-grid">
            <a href="/visualizer" class="tool-card card-vis">
                <div><div class="card-icon-wrapper" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;"><i class="fa-solid fa-globe"></i></div>
                <div class="card-content"><h3>Visualizador</h3><p>Campos vectoriales y escalares 3D.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/double-integral" class="tool-card card-int">
                <div><div class="card-icon-wrapper" style="background: rgba(249, 115, 22, 0.1); color: #f97316;"><i class="fa-solid fa-draw-polygon"></i></div>
                <div class="card-content"><h3>Integral Doble</h3><p>Volumen bajo superficie $\iint f dA$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/line-integral" class="tool-card card-int-line">
                <div><div class="card-icon-wrapper" style="background: rgba(234, 179, 8, 0.1); color: #eab308;"><i class="fa-solid fa-wave-square"></i></div>
                <div class="card-content"><h3>Integral de Línea</h3><p>Trabajo $\int \vec{F} \cdot d\vec{r}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/triple-integral" class="tool-card card-int-triple">
                <div><div class="card-icon-wrapper" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;"><i class="fa-solid fa-cube"></i></div>
                <div class="card-content"><h3>Integral Triple</h3><p>Masa y volumen $\iiint f dV$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
        </div>

        <div id="algebra" class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-vector-square" style="color:#10b981;"></i> Álgebra Vectorial</h2>
            <div class="section-line"></div>
        </div>
        <div class="dashboard-grid">
            <a href="/vector-sum" class="tool-card card-ops">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-plus-minus"></i></div>
                <div class="card-content"><h3>Suma y Resta</h3><p>Operaciones lineales $\vec{A} \pm \vec{B}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/vector-dot" class="tool-card card-dot">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-circle-dot"></i></div>
                <div class="card-content"><h3>Producto Punto</h3><p>Escalar y Ángulos $\vec{A} \cdot \vec{B}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
            <a href="/vector-cross" class="tool-card card-cross">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-xmark"></i></div>
                <div class="card-content"><h3>Producto Cruz</h3><p>Vector perpendicular $\vec{A} \times \vec{B}$.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
        </div>

        <div id="fisica" class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-bolt" style="color:#eab308;"></i> Física y Simulación</h2>
            <div class="section-line"></div>
        </div>
        <div class="dashboard-grid">
            <a href="/electrostatics" class="tool-card" style="border-top: 1px solid #eab308;">
                <div><div class="card-icon-wrapper" style="background: rgba(234, 179, 8, 0.1); color: #eab308;"><i class="fa-solid fa-bolt"></i></div>
                <div class="card-content"><h3>Simulador Electrostático</h3><p>Fuerzas y Campos Eléctricos.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
        </div>

        <div id="utilidades" class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-layer-group" style="color:#ec4899;"></i> Utilidades</h2>
            <div class="section-line"></div>
        </div>
        <div class="dashboard-grid">
            <a href="/history" class="tool-card card-hist">
                <div><div class="card-icon-wrapper"><i class="fa-solid fa-clock-rotate-left"></i></div>
                <div class="card-content"><h3>Historial</h3><p>Registro de cálculos realizados.</p></div></div>
                <i class="fa-solid fa-arrow-right card-arrow"></i>
            </a>
        </div>

    </div>
</body>
</html>