<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Integral Doble | VectorSys</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/integrals" class="active">Integrales</a>
            <a href="/line-integral" class="">Integral de Línea</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        <div class="panel" style="justify-content: flex-start;">
            <h2 style="margin:0;">Integral Doble</h2>
            <p style="color:#aaa; font-size:0.8rem; margin-bottom:20px;">Calcula $\iint_R f(x,y) \,dA$</p>
            <form action="/double-integral" method="POST">
                <div class="input-group">
                    <label class="label-text">Función $f(x,y)$</label>
                    <input type="text" class="modern-input" name="func" value="<%= func || 'x^2 + y^2' %>" placeholder="Ej: x*y">
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">X min</label><input type="number" step="any" class="modern-input" name="xmin" value="<%= xmin || -2 %>"></div>
                    <div class="input-group"><label class="label-text">X max</label><input type="number" step="any" class="modern-input" name="xmax" value="<%= xmax || 2 %>"></div>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">Y min</label><input type="number" step="any" class="modern-input" name="ymin" value="<%= ymin || -2 %>"></div>
                    <div class="input-group"><label class="label-text">Y max</label><input type="number" step="any" class="modern-input" name="ymax" value="<%= ymax || 2 %>"></div>
                </div>
                <button type="submit" class="btn btn-primary">Calcular Volumen</button>
            </form>
        </div>

        <div class="panel">
            <% if (locals.result) { %>
                <div class="result-box">
                    <span style="color:#f97316; font-size:0.9rem; text-transform:uppercase;">Volumen Aproximado</span>
                    <div class="result-val"><%= result %> u³</div>
                </div>
                <div id="plotDiv"></div>
            <% } else { %>
                <div class="empty-container">
                    <i class="fa-solid fa-draw-polygon empty-icon"></i>
                    <h2 style="margin-bottom: 10px;">Integral Doble</h2>
                    <p>Visualiza el volumen bajo la superficie y calcula su valor.</p>
                </div>
            <% } %>
        </div>
    </div>
    <script>
        const xData = JSON.parse('<%- JSON.stringify(xData || []) %>');
        const yData = JSON.parse('<%- JSON.stringify(yData || []) %>');
        const zData = JSON.parse('<%- JSON.stringify(zData || []) %>');
        if(zData.length > 0) {
            Plotly.newPlot('plotDiv', [{
                z: zData, x: xData, y: yData, type: 'surface',
                colorscale: 'Oranges',
                contours: { z: { show:true, usecolormap: true, project:{z: true} } }
            }], {
                margin: {l:0, r:0, b:0, t:0},
                paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
                scene: { xaxis: {color:'#fff'}, yaxis: {color:'#fff'}, zaxis: {color:'#fff'} }
            }, {responsive: true});
        }
    </script>
</body>
</html>