<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    <div class="lava-container">
</head>
<body>

    <div class="lava-container">
        <div class="blob b1"></div>
        <div class="blob b2"></div>
        <div class="blob b3"></div>
        <div class="blob b4"></div>
    </div>

    <div class="form-container">
        <div class="auth-header">
            <i class="fa-solid fa-layer-group"></i>
            <h2>Bienvenido</h2>
            <p class="auth-subtitle">Inicia sesión para continuar</p>
        </div>

        <% if (locals.errors && errors.length > 0) { %>
            <div style="background: rgba(244, 63, 94, 0.1); border: 1px solid var(--accent-rose); color: var(--accent-rose); padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: left;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right: 8px;"></i>
                <% errors.forEach(err => { %> <span style="display:block; margin-top:5px; font-size: 0.9rem;"><%= err.msg %></span> <% }) %>
            </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="input-group">
                <label class="label-text">Correo Electrónico</label>
                <div style="position: relative;">
                    <i class="fa-solid fa-envelope" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="email" class="modern-input" name="email" placeholder="tucorreo@ejemplo.com" required value="<%= locals.formData ? formData.email : '' %>" style="padding-left: 40px;">
                </div>
            </div>

            <div class="input-group">
                <label class="label-text">Contraseña</label>
                <div style="position: relative;">
                    <i class="fa-solid fa-lock" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="password" class="modern-input" name="password" placeholder="••••••••" required style="padding-left: 40px;">
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="margin-top: 24px;">Ingresar <i class="fa-solid fa-arrow-right"></i></button>
        </form>

        <div style="margin-top: 24px; font-size: 0.9rem; color: var(--text-secondary);">
            <span>¿No tienes cuenta?</span> <a href="/register" style="color: var(--accent-cyan); text-decoration: none; font-weight: 500;">Crear una ahora</a>
        </div>
    </div>

</body>
</html>