<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Integral de Línea | VectorSys</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/integrals" class="">Integrales</a>
            <a href="/line-integral" class="active">Integral de Línea</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        <div class="panel" style="justify-content: flex-start;">
            <h2 style="margin:0;">Integral de Línea</h2>
            <p style="color:#aaa; font-size:0.8rem; margin-bottom:20px;">Trabajo: $\int_C \vec{F} \cdot d\vec{r}$</p>
            <form action="/line-integral" method="POST">
                <div class="section-label">1. Campo Vectorial $\vec{F}$</div>
                <div class="input-group"><label class="label-text">P (i)</label><input type="text" class="modern-input" name="P" value="<%= P || 'y' %>"></div>
                <div class="input-group"><label class="label-text">Q (j)</label><input type="text" class="modern-input" name="Q" value="<%= Q || '-x' %>"></div>
                <div class="input-group"><label class="label-text">R (k)</label><input type="text" class="modern-input" name="R" value="<%= R || 'z' %>"></div>

                <div class="section-label">2. Trayectoria Paramétrica $\vec{r}(t)$</div>
                <div class="input-group"><label class="label-text">x(t)</label><input type="text" class="modern-input" name="xt" value="<%= xt || 'cos(t)' %>"></div>
                <div class="input-group"><label class="label-text">y(t)</label><input type="text" class="modern-input" name="yt" value="<%= yt || 'sin(t)' %>"></div>
                <div class="input-group"><label class="label-text">z(t)</label><input type="text" class="modern-input" name="zt" value="<%= zt || 't' %>"></div>

                <div class="section-label">3. Límites de $t$</div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">t inicio</label><input type="text" class="modern-input" name="t_start" value="<%= t_start || '0' %>"></div>
                    <div class="input-group"><label class="label-text">t fin</label><input type="text" class="modern-input" name="t_end" value="<%= t_end || '6.28' %>"></div>
                </div>
                <button type="submit" class="btn btn-primary">Calcular Trabajo</button>
            </form>
        </div>

        <div class="panel">
            <% if (locals.result) { %>
                <div class="result-box">
                    <span style="color:#eab308; font-size:0.9rem; text-transform:uppercase;">Trabajo Total</span>
                    <div class="result-val"><%= result %> J</div>
                </div>
                <div id="plotDiv"></div>
            <% } else { %>
                <div class="empty-container">
                    <i class="fa-solid fa-wave-square empty-icon"></i>
                    <h2 style="margin-bottom: 10px;">Integral de Línea</h2>
                    <p>Calcula el trabajo realizado por un campo sobre una trayectoria.</p>
                </div>
            <% } %>
        </div>
    </div>
    <script>
        const pathX = JSON.parse('<%- JSON.stringify(pathX || []) %>');
        const pathY = JSON.parse('<%- JSON.stringify(pathY || []) %>');
        const pathZ = JSON.parse('<%- JSON.stringify(pathZ || []) %>');
        if(pathX.length > 0) {
            Plotly.newPlot('plotDiv', [{
                type: 'scatter3d', mode: 'lines', x: pathX, y: pathY, z: pathZ,
                line: { width: 6, color: '#eab308' }, name: 'Trayectoria'
            }], {
                margin: {l:0, r:0, b:0, t:0},
                paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
                scene: { xaxis: {color:'#fff'}, yaxis: {color:'#fff'}, zaxis: {color:'#fff'}, gridcolor: '#333' },
                showlegend: false
            }, {responsive: true});
        }
    </script>
</body>
</html>