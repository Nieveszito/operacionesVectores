<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visualizador de Campos | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px;">
            <a href="#calculo" title="Cálculo Diferencial"><i class="fa-solid fa-wave-square"></i> Cálculo</a>
        <a href="#integrales" title="Integrales"><i class="fa-solid fa-chart-area"></i> Integrales</a>
        </div>

        <div class="nav-links">
            <a href="/history" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i> Historial</a>
            <a href="/logout" title="Cerrar Sesión"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        <div class="panel" style="justify-content: flex-start;">
            <h2 style="margin:0 0 20px 0;">Configuración</h2>
            <div class="type-switcher">
                <div class="switch-btn <%= (!type || type==='scalar') ? 'active' : '' %>" onclick="setType('scalar')">Escalar</div>
                <div class="switch-btn <%= (type==='vector') ? 'active' : '' %>" onclick="setType('vector')">Vectorial</div>
            </div>

            <form action="/visualizer" method="POST">
                <input type="hidden" name="type" id="inputType" value="<%= type || 'scalar' %>">
                <div id="scalarInputs" style="<%= type === 'vector' ? 'display:none' : 'display:block' %>">
                    <div class="input-group">
                        <label class="label-text">Función $z = f(x,y)$</label>
                        <input type="text" class="modern-input" name="funcZ" value="<%= funcZ || 'sin(x)*cos(y)' %>" placeholder="Ej: x^2 + y^2">
                    </div>
                </div>
                <div id="vectorInputs" style="<%= type !== 'vector' ? 'display:none' : 'display:block' %>">
                    <div class="input-group"><label class="label-text">P (i)</label><input type="text" class="modern-input" name="funcP" value="<%= funcP || '-y' %>"></div>
                    <div class="input-group"><label class="label-text">Q (j)</label><input type="text" class="modern-input" name="funcQ" value="<%= funcQ || 'x' %>"></div>
                    <div class="input-group"><label class="label-text">R (k)</label><input type="text" class="modern-input" name="funcR" value="<%= funcR || 'z/2' %>"></div>
                </div>
                <div class="input-group"><label class="label-text">Rango</label><input type="number" class="modern-input" name="range" value="<%= range || 5 %>" min="1" max="20"></div>
                <button type="submit" class="btn btn-primary">Graficar</button>
            </form>
        </div>

        <div class="panel" style="padding: 10px;">
            <% if (xData && xData.length > 0) { %>
                <div id="plotDiv"></div>
            <% } else { %>
                <div class="empty-container">
                    <i class="fa-solid fa-globe empty-icon"></i>
                    <h2 style="margin-bottom: 10px;">Visualizador 3D</h2>
                    <p>Ingresa una función o campo vectorial para generar la gráfica.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function setType(type) {
            document.getElementById('inputType').value = type;
            document.getElementById('scalarInputs').style.display = type === 'scalar' ? 'block' : 'none';
            document.getElementById('vectorInputs').style.display = type === 'vector' ? 'block' : 'none';
            document.querySelectorAll('.switch-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        const type = "<%= type || 'scalar' %>";
        // Si no hay datos, enviamos arrays vacios
        const xData = JSON.parse('<%- JSON.stringify(xData || []) %>');
        const yData = JSON.parse('<%- JSON.stringify(yData || []) %>');
        const zData = JSON.parse('<%- JSON.stringify(zData || []) %>');
        const uData = JSON.parse('<%- JSON.stringify(uData || []) %>');
        const vData = JSON.parse('<%- JSON.stringify(vData || []) %>');
        const wData = JSON.parse('<%- JSON.stringify(wData || []) %>');

        let data = [];
        let layout = {
            margin: {l:0, r:0, b:0, t:0},
            paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
            scene: { xaxis: {color:'#fff'}, yaxis: {color:'#fff'}, zaxis: {color:'#fff'}, gridcolor: '#333' },
            font: { color: '#fff' }
        };

        if (xData.length > 0) {
            if (type === 'scalar') {
                data = [{ z: zData, x: xData, y: yData, type: 'surface', colorscale: 'Viridis', contours: { z: { show: true, usecolormap: true, highlightcolor: "#limegreen", project: { z: true } } } }];
            } else {
                data = [{ type: 'cone', x: xData.flat(), y: yData.flat(), z: zData.flat(), u: uData.flat(), v: vData.flat(), w: wData.flat(), sizemode: 'scaled', sizeref: 2, colorscale: 'Portland', anchor: 'tail' }];
            }
            Plotly.newPlot('plotDiv', data, layout, {responsive: true});
        }
    </script>
</body>
</html>