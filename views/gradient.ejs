<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VectorSys | Pro</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>
        window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    

        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/gradient" class="active">Gradiente</a>
            <a href="/divergence" class="">Divergencia</a>
            <a href="/rotacional" class="">Rotacional</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>


    <div class="main-container calc-layout">
        
        <div class="panel panel-left">
            <div class="panel-header">
                <h1 class="panel-title">Gradiente</h1>
                <span class="panel-subtitle">Configuración de Parámetros</span>
            </div>

            <form action="/gradient" method="POST">
                <div class="input-group">
                    <label class="label-text">FUNCIÓN ESCALAR $f(x,y,z)$</label>
                    <input type="text" class="modern-input" name="funcion" 
                           placeholder="Ej: x^2 + y^2" 
                           required value="<%= locals.funcion || '' %>" autocomplete="off">
                </div>

                <div class="input-group">
                    <label class="label-text">PUNTO $(x_0, y_0, z_0)$</label>
                    <div class="coords-grid">
                        <input type="number" step="any" class="modern-input coord-box" name="x0" placeholder="X" required value="<%= locals.x0 || 0 %>">
                        <input type="number" step="any" class="modern-input coord-box" name="y0" placeholder="Y" required value="<%= locals.y0 || 0 %>">
                        <input type="number" step="any" class="modern-input coord-box" name="z0" placeholder="Z" required value="<%= locals.z0 || 0 %>">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Calcular <i class="fa-solid fa-bolt"></i>
                </button>
            </form>
        </div>


        <div class="panel panel-right <%= locals.resultado ? 'active' : '' %>">
            
            <% if (locals.resultado) { %>
                <div class="result-display">
                    <span class="result-label"><i class="fa-solid fa-check-circle"></i> Cálculo Exitoso</span>
                    
                    <div class="math-big">
                        $$ \nabla f = <%= resultado %> $$
                    </div>

                    <div class="stats">
                        <div class="stat-row">
                            <span>Magnitud $|\nabla f|$</span>
                            <span class="stat-val"><%= magnitud %></span>
                        </div>
                        <div class="stat-row">
                            <span>Evaluado en</span>
                            <span class="stat-val">(<%= x0 %>, <%= y0 %>, <%= z0 %>)</span>
                        </div>
                    </div>

                    <a href="/gradient" style="text-decoration: none; display: inline-block; margin-top: 20px; font-size: 0.8rem; color: #666; transition:0.3s;">
                        <i class="fa-solid fa-rotate-left"></i> Limpiar datos
                    </a>
                </div>

            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-arrow-trend-up empty-state-icon"></i>
                    <h3 style="margin:0; font-weight:500;">Listo para calcular</h3>
                    <p style="color:var(--text-muted); font-size:0.9rem; max-width: 200px; margin: 10px auto;">
                        Ingresa una función y un punto para visualizar el vector gradiente.
                    </p>
                </div>
            <% } %>

        </div>

    </div>

</body>
</html>