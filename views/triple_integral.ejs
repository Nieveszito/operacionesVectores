<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Integral Triple | VectorSys</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px;">
            <a href="#calculo" title="Cálculo Diferencial"><i class="fa-solid fa-wave-square"></i> Cálculo</a>
        <a href="#integrales" title="Integrales"><i class="fa-solid fa-chart-area"></i> Integrales</a>
        </div>

        <div class="nav-links">
            <a href="/history" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i> Historial</a>
            <a href="/logout" title="Cerrar Sesión"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        <div class="panel" style="justify-content: flex-start;">
            <h2 style="margin:0;">Integral Triple</h2>
            <p style="color:#aaa; font-size:0.8rem; margin-bottom:20px;">Masa/Volumen: $\iiint f(x,y,z) \,dV$</p>
            <form action="/triple-integral" method="POST">
                <div class="input-group">
                    <label class="label-text">Función $f(x,y,z)$ ('1' para volumen)</label>
                    <input type="text" class="modern-input" name="func" value="<%= func || '1' %>" placeholder="Ej: x*y*z">
                </div>
                
                <div class="section-label">Límites (Caja Rectangular)</div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">X min</label><input type="number" step="any" class="modern-input" name="xmin" value="<%= xmin || 0 %>"></div>
                    <div class="input-group"><label class="label-text">X max</label><input type="number" step="any" class="modern-input" name="xmax" value="<%= xmax || 1 %>"></div>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">Y min</label><input type="number" step="any" class="modern-input" name="ymin" value="<%= ymin || 0 %>"></div>
                    <div class="input-group"><label class="label-text">Y max</label><input type="number" step="any" class="modern-input" name="ymax" value="<%= ymax || 1 %>"></div>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="input-group"><label class="label-text">Z min</label><input type="number" step="any" class="modern-input" name="zmin" value="<%= zmin || 0 %>"></div>
                    <div class="input-group"><label class="label-text">Z max</label><input type="number" step="any" class="modern-input" name="zmax" value="<%= zmax || 1 %>"></div>
                </div>
                <button type="submit" class="btn btn-primary">Calcular</button>
            </form>
        </div>

        <div class="panel">
            <% if (locals.result) { %>
                <div class="result-box">
                    <span style="color:#8b5cf6; font-size:0.9rem; text-transform:uppercase;">Resultado</span>
                    <div class="result-val"><%= result %></div>
                </div>
            <% } else { %>
                <div class="empty-container">
                    <i class="fa-solid fa-cube empty-icon"></i>
                    <h2 style="margin-bottom: 10px;">Integral Triple</h2>
                    <p>Calcula el volumen o la masa de una región 3D.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>