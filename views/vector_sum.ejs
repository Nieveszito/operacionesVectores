<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suma Vectorial | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/vector-sum" class="active">Suma</a>
            <a href="/vector-dot" class="">Punto</a>
            <a href="/vector-cross" class="">Cruz</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        
        <div class="panel panel-left">
            <div class="panel-header">
                <h1 class="panel-title">Suma Vectorial</h1>
                <span class="panel-subtitle">Operaciones Lineales $\vec{A} \pm \vec{B}$</span>
            </div>
            
            <form action="/vector-sum" method="POST">
                <div class="input-group">
                    <label class="label-text">Vector $\vec{A}$ (separado por comas)</label>
                    <input type="text" class="modern-input" name="vecA" placeholder="Ej: 1, 2, 3" required value="<%= locals.vecA || '' %>">
                </div>
                <div class="input-group">
                    <label class="label-text">Vector $\vec{B}$ (separado por comas)</label>
                    <input type="text" class="modern-input" name="vecB" placeholder="Ej: 4, 5, 6" required value="<%= locals.vecB || '' %>">
                </div>
                <div class="input-group">
                    <label class="label-text">Operación</label>
                    <select class="modern-input" name="operacion" style="cursor: pointer;">
                        <option value="suma" <%= locals.operacion === 'suma' ? 'selected' : '' %>>Suma ($\vec{A} + \vec{B}$)</option>
                        <option value="resta" <%= locals.operacion === 'resta' ? 'selected' : '' %>>Resta ($\vec{A} - \vec{B}$)</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Calcular <i class="fa-solid fa-calculator" style="margin-left:8px"></i></button>
            </form>
        </div>

        <div class="panel panel-right <%= locals.resultado ? 'active' : '' %>">
            
            <% if (locals.resultado) { %>
                <div style="text-align: left;">
                    <span style="color:var(--accent-primary); font-size:0.8rem; font-weight:700; text-transform:uppercase;">Resultado</span>
                    <div style="font-size: 2rem; margin: 10px 0; font-weight: 600;">$$ \vec{R} = <%= resultado %> $$</div>
                </div>
                
                <div id="plotDiv"></div>

                <script>
                    // Capturamos los datos del servidor de forma segura para el editor
                    const ax = Number("<%= typeof ax !== 'undefined' ? ax : 0 %>");
                    const ay = Number("<%= typeof ay !== 'undefined' ? ay : 0 %>");
                    const az = Number("<%= typeof az !== 'undefined' ? az : 0 %>");

                    const bx = Number("<%= typeof bx !== 'undefined' ? bx : 0 %>");
                    const by = Number("<%= typeof by !== 'undefined' ? by : 0 %>");
                    const bz = Number("<%= typeof bz !== 'undefined' ? bz : 0 %>");

                    const rx = Number("<%= typeof rx !== 'undefined' ? rx : 0 %>");
                    const ry = Number("<%= typeof ry !== 'undefined' ? ry : 0 %>");
                    const rz = Number("<%= typeof rz !== 'undefined' ? rz : 0 %>");

                    // Definimos los trazos para Plotly
                    const traceA = { 
                        x: [0, ax], y: [0, ay], z: [0, az], 
                        mode: 'lines+markers', type: 'scatter3d', name: 'Vec A', 
                        line: {width: 6, color: '#42a5f5'} 
                    };
                    const traceB = { 
                        x: [0, bx], y: [0, by], z: [0, bz], 
                        mode: 'lines+markers', type: 'scatter3d', name: 'Vec B', 
                        line: {width: 6, color: '#ab47bc'} 
                    };
                    const traceR = { 
                        x: [0, rx], y: [0, ry], z: [0, rz], 
                        mode: 'lines+markers', type: 'scatter3d', name: 'Resultado', 
                        line: {width: 10, color: '#10b981'} 
                    };
                    
                    const layout = {
                        margin: {l:0, r:0, b:0, t:0},
                        paper_bgcolor: 'rgba(0,0,0,0)', 
                        plot_bgcolor: 'rgba(0,0,0,0)',
                        scene: {
                            xaxis: {title: 'X', color:'white'}, 
                            yaxis: {title: 'Y', color:'white'}, 
                            zaxis: {title: 'Z', color:'white'},
                            bgcolor: 'rgba(0,0,0,0)'
                        },
                        legend: {x: 0, y: 1, font: {color: 'white'}}
                    };

                    Plotly.newPlot('plotDiv', [traceA, traceB, traceR], layout, {displayModeBar: false});
                </script>

                <a href="/vector-sum" style="display:block; text-align:center; margin-top:20px; color:#aaa; text-decoration:none;">
                    <i class="fa-solid fa-rotate-left"></i> Limpiar
                </a>

            <% } else { %>
                
                <div class="empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%;">
                    <i class="fa-solid fa-plus-minus empty-state-icon"></i>
                    <h3 style="margin:0;">Suma Vectorial</h3>
                    <p style="color:var(--text-muted); font-size:0.9rem;">Visualiza la resultante gráfica.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>