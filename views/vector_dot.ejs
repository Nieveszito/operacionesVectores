<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Producto Punto | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>
    
    
        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/vector-sum" class="">Suma</a>
            <a href="/vector-dot" class="active">Punto</a>
            <a href="/vector-cross" class="">Cruz</a>
            <a href="/vector-angle" class="">Ángulo</a>
            <a href="/vector-triple-scalar" class="">Triple Escalar</a>
            <a href="/vector-triple-vector" class="">Triple Vectorial</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        
        <div class="panel panel-left">
            <div class="panel-header">
                <h1 class="panel-title">Producto Punto</h1>
                <span class="panel-subtitle">Escalar y Ángulo $\vec{A} \cdot \vec{B}$</span>
            </div>
            
            <form action="/vector-dot" method="POST">
                <div class="input-group">
                    <label class="label-text">Vector $\vec{A}$ (separado por comas)</label>
                    <input type="text" class="modern-input" name="vecA" placeholder="Ej: 1, 0, 0" required value="<%= locals.vecA || '' %>">
                </div>
                <div class="input-group">
                    <label class="label-text">Vector $\vec{B}$ (separado por comas)</label>
                    <input type="text" class="modern-input" name="vecB" placeholder="Ej: 0, 1, 0" required value="<%= locals.vecB || '' %>">
                </div>
                
                <button type="submit" class="btn btn-primary">Calcular <i class="fa-solid fa-calculator" style="margin-left:8px"></i></button>
            </form>
        </div>

        <div class="panel panel-right <%= locals.resultado ? 'active' : '' %>">
            
            <% if (locals.resultado) { %>
                <div style="text-align: left;">
                    <span style="color:var(--accent-primary); font-size:0.8rem; font-weight:700; text-transform:uppercase;">Resultado Escalar</span>
                    <div style="font-size: 2.5rem; margin: 10px 0; font-weight: 600;">
                        $$ \vec{A} \cdot \vec{B} = <%= resultado %> $$
                    </div>

                    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 15px; display: flex; align-items: center; justify-content: space-between; margin-top: 15px;">
                        <span style="color: var(--text-muted); font-size: 0.9rem;">Ángulo entre vectores ($\theta$)</span>
                        <span style="font-size: 1.2rem; font-weight: 600; color: #fff;">
                            <%= angulo %>^\circ
                        </span>
                    </div>
                </div>
                
                <div id="plotDiv"></div>

                <script>
                    // Capturamos vectores (si existen, o 0)
                    // Como el producto punto se usa mucho para ángulos, visualizamos los vectores originales
                    let ax, ay, az, bx, by, bz;
                    
                    try {
                        const vecAStr = "<%= typeof vecA !== 'undefined' ? vecA : '0,0,0' %>";
                        const vecBStr = "<%= typeof vecB !== 'undefined' ? vecB : '0,0,0' %>";
                        
                        const arrA = vecAStr.split(',').map(Number);
                        const arrB = vecBStr.split(',').map(Number);

                        ax = arrA[0] || 0; ay = arrA[1] || 0; az = arrA[2] || 0;
                        bx = arrB[0] || 0; by = arrB[1] || 0; bz = arrB[2] || 0;
                    } catch(e) {
                        ax=0; ay=0; az=0; bx=0; by=0; bz=0;
                    }

                    // Definimos los trazos para Plotly
                    const traceA = { 
                        x: [0, ax], y: [0, ay], z: [0, az], 
                        mode: 'lines+markers', type: 'scatter3d', name: 'Vec A', 
                        line: {width: 8, color: '#06b6d4'} // Cyan
                    };
                    const traceB = { 
                        x: [0, bx], y: [0, by], z: [0, bz], 
                        mode: 'lines+markers', type: 'scatter3d', name: 'Vec B', 
                        line: {width: 8, color: '#a855f7'} // Morado para contraste
                    };
                    
                    const layout = {
                        margin: {l:0, r:0, b:0, t:0},
                        paper_bgcolor: 'rgba(0,0,0,0)', 
                        plot_bgcolor: 'rgba(0,0,0,0)',
                        scene: {
                            xaxis: {title: 'X', color:'white'}, 
                            yaxis: {title: 'Y', color:'white'}, 
                            zaxis: {title: 'Z', color:'white'},
                            bgcolor: 'rgba(0,0,0,0)'
                        },
                        legend: {x: 0, y: 1, font: {color: 'white'}}
                    };

                    Plotly.newPlot('plotDiv', [traceA, traceB], layout, {displayModeBar: false});
                </script>

                <a href="/vector-dot" style="display:block; text-align:center; margin-top:20px; color:#aaa; text-decoration:none;">
                    <i class="fa-solid fa-rotate-left"></i> Limpiar
                </a>

            <% } else { %>
                
                <div class="empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%;">
                    <i class="fa-solid fa-circle-dot empty-state-icon"></i>
                    <h3 style="margin:0;">Producto Punto</h3>
                    <p style="color:var(--text-muted); font-size:0.9rem;">Calcula proyecciones y ángulos.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>