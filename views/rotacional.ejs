<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rotacional | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>
        window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] } };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    

        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/gradient" class="">Gradiente</a>
            <a href="/divergence" class="">Divergencia</a>
            <a href="/rotacional" class="active">Rotacional</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="main-container calc-layout">
        
        <div class="panel panel-left">
            <div class="panel-header">
                <h1 class="panel-title">Rotacional</h1>
                <span class="panel-subtitle">Calcula el Vector de Giro $\nabla \times \vec{F}$</span>
            </div>

            <form action="/rotacional" method="POST">
                
                <div class="input-group">
                    <label class="label-text">
                        <span>Función Escalar $P(x,y,z)$</span>
                        <span class="math-badge">Dirección $\hat{i}$</span>
                    </label>
                    <input type="text" class="modern-input" name="P" placeholder="Ej: y" required value="<%= locals.P || '' %>" autocomplete="off">
                </div>

                <div class="input-group">
                    <label class="label-text">
                        <span>Función Escalar $Q(x,y,z)$</span>
                        <span class="math-badge">Dirección $\hat{j}$</span>
                    </label>
                    <input type="text" class="modern-input" name="Q" placeholder="Ej: -x" required value="<%= locals.Q || '' %>" autocomplete="off">
                </div>

                <div class="input-group">
                    <label class="label-text">
                        <span>Función Escalar $R(x,y,z)$</span>
                        <span class="math-badge">Dirección $\hat{k}$</span>
                    </label>
                    <input type="text" class="modern-input" name="R" placeholder="Ej: 0" required value="<%= locals.R || '' %>" autocomplete="off">
                </div>

                <div class="input-group">
                    <label class="label-text">Punto de Evaluación $(x_0, y_0, z_0)$</label>
                    <div class="coords-grid">
                        <input type="number" step="any" class="modern-input coord-box" name="x0" placeholder="X" required value="<%= locals.x0 || 0 %>">
                        <input type="number" step="any" class="modern-input coord-box" name="y0" placeholder="Y" required value="<%= locals.y0 || 0 %>">
                        <input type="number" step="any" class="modern-input coord-box" name="z0" placeholder="Z" required value="<%= locals.z0 || 0 %>">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Calcular <i class="fa-solid fa-bolt" style="margin-left:8px"></i></button>
            </form>
        </div>

        <div class="panel panel-right <%= locals.resultado ? 'active' : '' %>">
            <% if (locals.resultado) { %>
                <div class="result-display">
                    <span style="color:var(--accent-primary); font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:20px; display:block;">
                        <i class="fa-solid fa-check-circle"></i> Resultado Vectorial
                    </span>
                    
                    <div class="math-big">
                        $$ \nabla \times \vec{F} = <%= resultado %> $$
                    </div>

                    <div style="display:flex; justify-content:space-between; color: var(--text-muted); font-size: 0.9rem;">
                        <span>Magnitud del giro:</span>
                        <span style="color:#fff; font-weight:600;">$$ | \nabla \times \vec{F} | = <%= magnitud %> $$</span>
                    </div>

                    <a href="/rotacional" style="text-decoration: none; display: inline-block; margin-top: 30px; font-size: 0.8rem; color: #aaa;">
                        <i class="fa-solid fa-rotate-left"></i> Limpiar datos
                    </a>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-rotate empty-state-icon"></i>
                    <h3 style="margin:0; font-weight:500;">Rotacional</h3>
                    <p style="color:var(--text-muted); font-size:0.9rem; max-width: 200px; margin: 10px auto;">
                        Calcula la tendencia de rotación del campo vectorial.
                    </p>
                </div>
            <% } %>
        </div>

    </div>
</body>
</html>