<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    <div class="form-container">
        <div class="auth-header">
            <i class="fa-solid fa-rocket"></i>
            <h2>Crear Cuenta</h2>
            <p class="auth-subtitle">Únete a la plataforma vectorial</p>
        </div>

        <% if (locals.errors && errors.length > 0) { %>
            <div style="background: rgba(244, 63, 94, 0.1); border: 1px solid var(--accent-rose); color: var(--accent-rose); padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: left;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right: 8px;"></i>
                <% errors.forEach(err => { %> <span style="display:block; margin-top:5px; font-size: 0.9rem;"><%= err.msg %></span> <% }) %>
            </div>
        <% } %>

        <form id="registerForm" action="/register" method="POST" novalidate>
            <div class="input-group">
                <label class="label-text">Nombre de Usuario</label>
                <div style="position: relative;">
                    <i class="fa-regular fa-user" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="text" class="modern-input" id="username" name="username" placeholder="Tu nombre" required minlength="3" value="<%= locals.formData ? formData.username : '' %>" style="padding-left: 40px;">
                </div>
                <div class="error-hint" id="hint-username" style="display:none; color: var(--accent-rose); font-size: 0.8rem; margin-top: 5px;">Mínimo 3 caracteres</div>
            </div>

            <div class="input-group">
                <label class="label-text">Correo Electrónico</label>
                <div style="position: relative;">
                    <i class="fa-regular fa-envelope" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="email" class="modern-input" id="email" name="email" placeholder="tucorreo@ejemplo.com" required value="<%= locals.formData ? formData.email : '' %>" style="padding-left: 40px;">
                </div>
                <div class="error-hint" id="hint-email" style="display:none; color: var(--accent-rose); font-size: 0.8rem; margin-top: 5px;">Correo inválido</div>
            </div>

            <div class="input-group">
                <label class="label-text">Contraseña</label>
                <div style="position: relative;">
                    <i class="fa-solid fa-lock" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="password" class="modern-input" id="password" name="password" placeholder="••••••••" required minlength="6" style="padding-left: 40px;">
                </div>
                <div class="error-hint" id="hint-password" style="display:none; color: var(--accent-rose); font-size: 0.8rem; margin-top: 5px;">Mínimo 6 caracteres</div>
            </div>

            <div class="input-group">
                <label class="label-text">Confirmar Contraseña</label>
                <div style="position: relative;">
                    <i class="fa-solid fa-check-double" style="position: absolute; left: 14px; top: 14px; color: var(--text-secondary);"></i>
                    <input type="password" class="modern-input" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required style="padding-left: 40px;">
                </div>
                <div class="error-hint" id="hint-match" style="display:none; color: var(--accent-rose); font-size: 0.8rem; margin-top: 5px;">No coinciden</div>
            </div>

            <button type="submit" class="btn btn-primary" id="submitBtn" style="margin-top: 24px;">Registrarse <i class="fa-solid fa-arrow-right"></i></button>
        </form>

        <div style="margin-top: 24px; font-size: 0.9rem; color: var(--text-secondary);">
            <span>¿Ya tienes cuenta?</span> <a href="/login" style="color: var(--accent-cyan); text-decoration: none; font-weight: 500;">Inicia Sesión</a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const inputs = document.querySelectorAll('input');
            
            const validate = (input) => {
                const hint = document.getElementById('hint-' + (input.id === 'confirmPassword' ? 'match' : input.id));
                let valid = true;
                
                if (input.id === 'username' && input.value.length < 3) valid = false;
                if (input.id === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) valid = false;
                if (input.id === 'password' && input.value.length < 6) valid = false;
                if (input.id === 'confirmPassword') {
                    const pass = document.getElementById('password').value;
                    if (input.value !== pass || input.value === '') valid = false;
                }

                if (!valid && input.value.length > 0) {
                    input.style.borderColor = 'var(--accent-rose)';
                    if(hint) hint.style.display = 'block';
                } else {
                    input.style.borderColor = 'var(--border-subtle)';
                    if(hint) hint.style.display = 'none';
                }
            };

            inputs.forEach(input => {
                input.addEventListener('input', () => validate(input));
                input.addEventListener('blur', () => validate(input));
            });
        });
    </script>
</body>
</html>