<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historial | VectorSys</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    
    <link rel="stylesheet" href="/css/vectorsys-theme.css">
</head>
<body>

    

        <nav class="navbar-clean" style="justify-content: space-between; padding: 0 30px;">
        <a href="/dashboard" class="nav-brand"><i class="fa-solid fa-bolt" style="color: var(--text-primary);"></i> VectorSys</a>
        
        <div class="nav-links" style="background: rgba(15, 15, 20, 0.45); backdrop-filter: blur(16px); padding: 8px 20px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); display: flex; gap: 15px; flex-wrap: wrap;">
            <a href="/vector-sum">Lineal</a>
            <a href="/vector-dot">Punto</a>
            <a href="/vector-cross">Cruz</a>
            <a href="/gradient">Campos</a>
        </div>

        <div class="nav-links">
            <a href="/history" class="active" title="Historial"><i class="fa-solid fa-clock-rotate-left"></i></a>
            <a href="/logout" title="Salir"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </nav>

    <div class="container">
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert-box">
                <i class="fa-solid fa-check-circle"></i> <%= message %>
            </div>
            <script>setTimeout(() => { document.querySelector('.alert-box').style.display = 'none'; }, 4000);</script>
        <% } %>

        <div class="header-section">
            <div class="page-title">
                <span>Registro de Actividad</span>
                <h1>Historial</h1>
            </div>
            <div style="font-size: 0.9rem; color: var(--text-muted);">
                <i class="fa-solid fa-database"></i> Total: <%= operations ? operations.length : 0 %> registros
            </div>
        </div>

        <div class="table-container">
            <% if (operations && operations.length > 0) { %>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th style="min-width: 250px;">Entrada (Datos)</th>
                            <th>Resultado</th>
                            <th>Fecha</th>
                            <th style="text-align: right;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% operations.forEach(op => { %>
                            <tr>
                                <td>
                                    <% 
                                        let badgeClass = 'badge-default';
                                        let icon = 'fa-calculator';
                                        let label = op.operation_type;

                                        if(op.operation_type === 'suma' || op.operation_type === 'resta') {
                                            badgeClass = 'badge-suma'; icon = 'fa-plus-minus'; label = 'Lineal';
                                        } else if (op.operation_type === 'productoPunto' || op.operation_type === 'angulo') {
                                            badgeClass = 'badge-dot'; icon = 'fa-circle-dot'; label = 'Punto';
                                        } else if (op.operation_type === 'productoCruz' || op.operation_type.includes('triple')) {
                                            badgeClass = 'badge-cross'; icon = 'fa-xmark'; label = 'Vectorial';
                                        } else if (op.operation_type === 'gradiente') {
                                            badgeClass = 'badge-grad'; icon = 'fa-arrow-trend-up'; label = 'Gradiente';
                                        } else if (op.operation_type === 'divergencia') {
                                            badgeClass = 'badge-div'; icon = 'fa-maximize'; label = 'Divergencia';
                                        } else if (op.operation_type === 'rotacional') {
                                            badgeClass = 'badge-rot'; icon = 'fa-rotate'; label = 'Rotacional';
                                        }
                                    %>
                                    <span class="badge <%= badgeClass %>">
                                        <i class="fa-solid <%= icon %>"></i> <%= label %>
                                    </span>
                                </td>

                                <td>
                                    <div class="input-grid">
                                        <% if (['gradiente','divergencia','rotacional'].includes(op.operation_type)) { %>
                                            <span class="input-label">Func:</span>
                                            <span class="vector-font"><%= op.vector_a %></span>
                                            
                                            <% if(op.vector_b && op.vector_b !== '0,0,0') { %>
                                                <span class="input-label">Pto/Q:</span>
                                                <span class="vector-font"><%= op.vector_b %></span>
                                            <% } %>
                                            
                                            <% if(op.vector_c && op.vector_c !== '0,0,0') { %>
                                                <span class="input-label">R:</span>
                                                <span class="vector-font"><%= op.vector_c %></span>
                                            <% } %>

                                        <% } else { %>
                                            <span class="input-label">A:</span>
                                            <span class="vector-font"><%= op.vector_a %></span>
                                            
                                            <span class="input-label">B:</span>
                                            <span class="vector-font"><%= op.vector_b %></span>
                                        <% } %>
                                    </div>
                                </td>

                                <td>
                                    <span class="vector-font" style="color: var(--accent-primary); border-color: rgba(236, 72, 153, 0.3); text-align:center;">
                                        <%= op.result %>
                                    </span>
                                </td>

                                <td>
                                    <div class="date-text">
                                        <i class="fa-regular fa-calendar" style="margin-right:5px;"></i>
                                        <%= new Date(op.created_at).toLocaleDateString() %>
                                    </div>
                                    <div class="date-text" style="font-size: 0.75rem; opacity: 0.7;">
                                        <%= new Date(op.created_at).toLocaleTimeString() %>
                                    </div>
                                </td>

                                <td style="text-align: right;">
                                    <a href="/download-pdf/<%= op.id %>" class="action-btn btn-pdf" title="Descargar PDF">
                                        <i class="fa-solid fa-file-arrow-down"></i>
                                    </a>
                                    <form action="/history/delete/<%= op.id %>" method="POST" style="display:inline;">
                                        <button type="submit" class="action-btn btn-del" title="Eliminar" onclick="return confirm('¿Eliminar registro?')">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-clock-rotate-left empty-icon"></i>
                    <h3>Historial Vacío</h3>
                    <p>No hay registros disponibles.</p>
                    <a href="/dashboard" style="color: var(--accent-primary); text-decoration: none;">Ir al Dashboard &rarr;</a>
                </div>
            <% } %>
        </div>

    </div>
</body>
</html>